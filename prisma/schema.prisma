// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ItemStatus {
  PENDING
  ACTIVE
  SOLD
  BANNED
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  PURCHASE
  SALE
  FEE
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum EscrowStatus {
  CREATED
  WAITING_DELIVERY
  DISPUTE
  COMPLETED
  CANCELED
}

// Модель пользователя: содержит баланс и роль (ADMIN/USER)
// Фронтендеры (@polad): Обратите внимание, telegram_id - это BigInt, 
// баланс представлен в виде Decimal (строка в JSON ответах API).
model User {
  id             String         @id @default(uuid())
  telegram_id    BigInt         @unique
  username       String?
  balance        Decimal        @default(0.00) @db.Decimal(10, 2)
  role           Role           @default(USER)
  created_at     DateTime       @default(now())

  // Связи
  items          Item[]         @relation("UserItems")
  transactions   Transaction[]
  
  // Сделки
  deals_as_buyer EscrowDeal[]   @relation("BuyerDeals")
  deals_as_seller EscrowDeal[]  @relation("SellerDeals")

  @@index([telegram_id])
}

// Категории товаров
// Фронтендеры: is_active используйте для фильтрации отображаемых категорий.
model Category {
  id         String   @id @default(uuid())
  name       String   @unique
  is_active  Boolean  @default(true)
  
  items      Item[]
}

// Объявление (Товар) на P2P платформе
// Фронтендеры: Изображения хранятся как массив URL строк (images String[]).
model Item {
  id          String      @id @default(uuid())
  title       String
  description String
  price       Decimal     @db.Decimal(10, 2)
  status      ItemStatus  @default(PENDING) // PENDING - на модерации
  images      String[]    // Массив URL картинок
  
  // Владелец/Продавец
  seller_id   String
  seller      User        @relation("UserItems", fields: [seller_id], references: [id])
  
  // Категория
  category_id String
  category    Category    @relation(fields: [category_id], references: [id])

  deals       EscrowDeal[]

  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
}

// Финансовые транзакции пользователя (пополнения, выводы, покупки, продажа)
model Transaction {
  id              String            @id @default(uuid())
  user_id         String
  user            User              @relation(fields: [user_id], references: [id])
  
  amount          Decimal           @db.Decimal(10, 2)
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  
  // Ссылка на сделку (опционально)
  related_deal_id String?
  deal            EscrowDeal?       @relation(fields: [related_deal_id], references: [id])
  
  created_at      DateTime          @default(now())
}

// Безопасная сделка (Escrow)
// Фронтендеры: Внимательно следите за цепочкой статусов сделки (CREATED -> WAITING_DELIVERY -> COMPLETED).
model EscrowDeal {
  id         String       @id @default(uuid())
  
  buyer_id   String
  buyer      User         @relation("BuyerDeals", fields: [buyer_id], references: [id])
  
  seller_id  String
  seller     User         @relation("SellerDeals", fields: [seller_id], references: [id])
  
  item_id    String
  item       Item         @relation(fields: [item_id], references: [id])
  
  status     EscrowStatus @default(CREATED)
  
  transactions Transaction[]

  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
}
